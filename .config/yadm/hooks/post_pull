#!/bin/bash

OS_TYPE="$(uname)"

if [ "$OS_TYPE" = "Darwin" ]; then
  echo "macOS detected. Validating Brewfiles..."
  if [ -f "$HOME/.Brewfile" ] && [ -f "$HOME/.Brewfile-darwin" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    brew bundle --global install --force --force-cleanup
  else
    echo "Missing ~/.Brewfile or ~/.Brewfile-darwin on Mac. Skipping sync."
  fi

elif [ "$OS_TYPE" = "Linux" ]; then
  echo "Linux detected. Validating Brewfile..."
  if [ -f "$HOME/.Brewfile" ]; then
    # Check if Linuxbrew is actually installed on this system/container
    if command -v brew &>/dev/null; then
      echo "~/.Brewfile found. Syncing Linuxbrew..."
      brew bundle --global install --force --force-cleanup
    elif [ -d /var/home/linuxbrew/.linuxbrew ]; then
      echo "~/.Brewfile found. Syncing Linuxbrew..."
      eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
      brew bundle --global install --force --force-cleanup
    else
      echo "ℹ️ ~/.Brewfile exists, but Homebrew/Linuxbrew is not installed on this machine. Skipping sync."
    fi
  else
    echo "~/.Brewfile not found on Linux. Skipping sync."
  fi

else
  echo "Unknown OS ($OS_TYPE). Skipping Homebrew sync."
fi
